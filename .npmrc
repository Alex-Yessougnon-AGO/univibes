# Hoist all packages to root node_modules (needed for Prisma + pnpm workspaces)
shamefully-hoist=true

# Allow build scripts for specific packages (pnpm v11 default)
only-built-dependencies[]=sharp
only-built-dependencies[]=@img/sharp-linux-x64
only-built-dependencies[]=@img/sharp-linux-arm64
only-built-dependencies[]=@img/sharp-libvips-linux-x64
only-built-dependencies[]=@img/sharp-libvips-linux-arm64
only-built-dependencies[]=@swc/core
only-built-dependencies[]=@parcel/watcher
only-built-dependencies[]=bcrypt
only-built-dependencies[]=prisma
only-built-dependencies[]=@prisma/client
only-built-dependencies[]=@prisma/engines
only-built-dependencies[]=@nestjs/core
