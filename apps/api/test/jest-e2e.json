{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@univibes/types$": "<rootDir>/../../packages/types/src",
    "^@univibes/utils$": "<rootDir>/../../packages/utils/src"
  }
}
