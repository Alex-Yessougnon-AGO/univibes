{
  "name": "univibes",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "db:generate": "PRISMA_GENERATE_SKIP_AUTOINSTALL=true prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "db:seed": "pnpm --filter api db:seed",
    "db:reset": "prisma migrate reset --schema=prisma/schema.prisma"
  },
  "devDependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0",
    "typescript": "^5.7.0"
  }
}
